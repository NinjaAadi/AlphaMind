# RAG service – optional overrides (defaults work if services run on usual ports)

# Your existing services (must be running for ingest)
MODEL_SERVICE_URL=http://localhost:8001
SCRAPER_API_URL=http://localhost:8000

# Ollama (free local LLM) – install from https://ollama.com, then: ollama run llama3.2
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# RAG
RAG_TOP_K=5
CHROMA_PERSIST_DIR=./chroma_data
# CHROMA_COLLECTION_NAME=alphamind_rag
# OLLAMA_TIMEOUT=90
# Load vector DB on server startup (default 1). Set to 0 to skip (e.g. if APIs not ready).
# PRELOAD_VECTOR_DB=1
# After this time (IST), queries use vector DB; ingest runs once per day first. Default 3:15 PM.
# MARKET_CLOSE_HOUR=15
# MARKET_CLOSE_MINUTE=15
# TIMEZONE=Asia/Kolkata
# Cron ingest: file with one stock symbol per line (default: ../model_service/training_stocks.txt)
# INGEST_STOCKS_FILE=../model_service/training_stocks.txt
# Testing single stock: ingest and preload only this stock (unset or leave empty for full list)
# SINGLE_STOCK=TCS
# TEST_SINGLE_STOCK=TCS

# API
PORT=8002
