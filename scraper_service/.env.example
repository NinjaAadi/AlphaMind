# Scraper service (AlphaMind) – optional overrides
# Copy to .env and set at least NEWS_API_KEY for news.

# Required for news: get a key from https://newsapi.org/
NEWS_API_KEY=your_newsapi_key_here

# RAG service URL – used when the UI "Ask the LLM" proxies to RAG (default 8002)
RAG_SERVICE_URL=http://localhost:8002

# Server
API_HOST=0.0.0.0
API_PORT=8000
# API_RELOAD=true

# SSL (set to false only if you hit certificate issues with yfinance/screener)
# SSL_VERIFY=true
