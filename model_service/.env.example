# Model service (AlphaMind) – optional overrides
# Scraper must be running; model service fetches features from it.

# Scraper API base URL (for prediction: fetch current stock data)
SCRAPER_API_URL=http://localhost:8000

# Prediction API server
PORT=8001

# Model file: .ckpt (Lightning) or .pt (state_dict). If unset, uses lightning_logs checkpoint or models/tft_stock_model.pt
# MODEL_PATH=/path/to/models/tft_stock_model.pt

# Data pipeline (run_pipeline.py): scraper endpoint for fetching training data
# API_URL=http://localhost:8000/stock
